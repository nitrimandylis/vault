# Notion integration token — create one at https://www.notion.so/my-integrations
# Make sure the integration has access to your Work Hub page.
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The Notion page ID of your "Work Hub" page.
# Find it in the page URL: notion.so/<workspace>/<PAGE_ID>?v=...
# Strip dashes if needed — the API accepts both formats.
NOTION_WORK_HUB_PAGE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
